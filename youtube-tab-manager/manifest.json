{
  "manifest_version": 3,
  "name": "YouTube Tab Manager",
  "version": "1.0",
  "description": "Collapse and manage your open YouTube tabs in a single dashboard.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "128": "icons/icon128.png"
    },
    "default_title": "Collapse YouTube Tabs"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Collapse YouTube tabs"
    }
  }
}
