{
  "manifest_version": 3,
  "name": "FoldTube - YouTube Tab Manager",
  "version": "1.0.4",
  "description": "Collapse and manage your open YouTube tabs in a single dashboard.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "128": "icons/icon128.png"
    },
    "default_title": "Collapse YouTube Tabs"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Collapse YouTube tabs"
    },
    "open-dashboard": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Open FoldTube dashboard without folding tabs"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "foldtube@osumapps.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}